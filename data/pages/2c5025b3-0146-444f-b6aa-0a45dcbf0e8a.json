          "text": "\n"
        },
        {
          "text": "/s/ in Puerto Rico ",
          "textSize": "heading-three"
        }
      ]
    },
    {
      "type": "paragraph",
      "children": [
        {
          "text": "The Spanish spoken by Puerto Ricans features a significant amount of /s/ reduction. "
        }
      ]
    },
    {
      "type": "paragraph",
      "children": [
        {
          "text": "[Insert table about Puerto Rican /s/ variation & compensation strategies]\n"
        }
      ]
    },
    {
      "type": "paragraph",
      "children": [
        {
          "text": "[Insert transcribed examples from an interview with reggaetón artists] "
        }
      ]
    },
    {
      "type": "paragraph",
      "children": [
        {
