      "event2": {
        "uuid": "827af6d7-cf18-43af-a1d1-a11c6e55f36c",
        "start": 6,
        "end": 79,
        "file": "dc0b0f05-3ed7-4e48-a885-e2660eb7aa66",
        "type": "Video"
