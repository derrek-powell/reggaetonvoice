        }
      ]
    },
    {
      "type": "paragraph",
      "children": [
        {
          "text": "Wisin ",
          "color": "#f7f3f3"
        }
      ]
    },
    {
      "type": "paragraph",
      "children": [
        {
          "text": "",
          "color": "#f7f3f3"
        }
      ]
    },
    {
      "type": "paragraph",
      "children": [
        {
          "text": "This feature is significantly less present but still present in the music of women, who seem to prefer a rhotic alternate ",
          "color": "#f7f3f3"
        }
      ]
    },
    {
      "type": "paragraph",
      "children": [
        {
          "text": "Ivy Queen ",
          "color": "#f7f3f3"
        }
