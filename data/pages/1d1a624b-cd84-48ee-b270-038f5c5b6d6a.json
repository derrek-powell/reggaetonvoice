      ],
      "event1": {
        "uuid": "c0c592c6-7f4f-4de7-98e8-d458b7669f87",
        "file": "6593dd3c-652d-4bba-a70b-968177e2d867",
        "type": "Video"
      },
      "event2": {
        "uuid": "c80e4e92-e86d-438c-8257-c4786fbf4c7c",
        "file": "f6709448-e121-40a4-bbe7-864877434eb2",
        "type": "Video"
      },
      "type": "event-comparison",
      "children": [
        {
          "text": ""
        }
      ]
    },
    {
      "type": "paragraph",
      "children": [
        {
          "text": "Below are some extremely popular samples that illustrate the prevalence of this riddim throughout the genre's development and global expansion. "
        }
      ]
    },
    {
      "type": "paragraph",
      "children": [
        {
          "text": ""
        }
      ]
    },
    {
      "includes": [
        "media",
        "annotations",
        "label",
        "description"
      ],
      "event1": {
        "uuid": "27b11444-db58-4485-b138-61aa4c6cdaf2",
        "start": 21,
        "end": 70,
        "file": "13f1ce37-851d-4f3e-84e6-3265f0545cb0",
        "type": "Video"
      },
      "event2": {
        "uuid": "490b78b9-3aee-4361-9098-b6f1e59a7118",
        "start": 62,
        "end": 148,
        "file": "f9fb65e1-21d6-42a7-8b4c-f47c72d4d4e2",
        "type": "Video"
      },
