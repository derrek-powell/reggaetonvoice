{"annotations":[{"start_time":75,"end_time":76,"annotation":[{"type":"paragraph","children":[{"text":"Mami relax que no[-]  fuimo[-] al compá[s]"}]}],"tags":[{"category":"_uncategorized_","tag":"s-retention"},{"category":"Sociolinguistic Behavior","tag":"s-reduction"},{"category":"Linguistic Level","tag":"phonology"},{"category":"Artists","tag":"J Balvin"}],"uuid":"5b54cd10-05be-4fa0-abc7-680ae4b294dc"},{"start_time":76,"end_time":78,"annotation":[{"type":"paragraph","children":[{"text":"De la i[-]la sonando esa hay una fie[s]ta"}]}],"tags":[{"category":"_uncategorized_","tag":"s-retention"},{"category":"Sociolinguistic Behavior","tag":"s-reduction"},{"category":"Linguistic Level","tag":"phonology"},{"category":"Artists","tag":"J Balvin"}],"uuid":"d91d5a6e-8626-4160-8882-ee13217ca313"},{"start_time":78,"end_time":81,"annotation":[{"type":"paragraph","children":[{"text":"Allá hay mucho bonsái lo[s] ojito[-] en Thai"}]}],"tags":[{"category":"_uncategorized_","tag":"s-retention"},{"category":"Sociolinguistic Behavior","tag":"s-reduction"},{"category":"Linguistic Level","tag":"phonology"},{"category":"Artists","tag":"J Balvin"}],"uuid":"b94e729e-ec23-45ed-86a7-f7792dd36805"},{"start_time":81,"end_time":84,"annotation":[{"type":"paragraph","children":[{"text":"Y modo pad and sai con la crepa"}]}],"tags":[{"category":"_uncategorized_","tag":"NA"}],"uuid":"8929bad5-29bb-47cc-9f27-82fb3b00b325"},{"start_time":84,"end_time":87,"annotation":[{"type":"paragraph","children":[{"text":"Te voy a perdonar si te pone[-] media culisuelta"}]}],"tags":[{"category":"Sociolinguistic Behavior","tag":"s-reduction"},{"category":"Linguistic Level","tag":"phonology"},{"category":"Artists","tag":"J Balvin"}],"uuid":"7345c462-2360-40ad-b836-67bfca524f61"},{"start_time":87,"end_time":89,"annotation":[{"type":"paragraph","children":[{"text":"Tú no ere[-] mortera pero tensa"}]}],"tags":[{"category":"Sociolinguistic Behavior","tag":"s-reduction"},{"category":"Linguistic Level","tag":"phonology"},{"category":"Artists","tag":"J Balvin"}],"uuid":"e0d0e32f-8ee0-4d27-bb8a-e4fa08cdb714"},{"start_time":89,"end_time":91,"annotation":[{"type":"paragraph","children":[{"text":"E[-] una baddie bad gyal, no se va a comportar"}]}],"tags":[{"category":"Sociolinguistic Behavior","tag":"s-reduction"},{"category":"Linguistic Level","tag":"phonology"},{"category":"Artists","tag":"J Balvin"}],"uuid":"ea9f6f4d-f17f-4d9e-8b34-6fa0cc57ebd6"},{"start_time":91,"end_time":93,"annotation":[{"type":"paragraph","children":[{"text":"Y la voy a detonar pa' que ella aprenda"}]}],"tags":[{"category":"_uncategorized_","tag":"NA"}],"uuid":"7aa5ea1c-0173-48b6-8b31-01fc73c6eb78"},{"start_time":93,"end_time":97,"annotation":[{"type":"paragraph","children":[{"text":"Ya give me the light, tú e[-]tá[-] rica mai"}]}],"tags":[{"category":"Sociolinguistic Behavior","tag":"s-reduction"},{"category":"Linguistic Level","tag":"phonology"},{"category":"Artists","tag":"J Balvin"}],"uuid":"6874a646-62ed-41ba-b28e-565449d82794"},{"start_time":97,"end_time":99,"annotation":[{"type":"paragraph","children":[{"text":"Una vuelta por el ghetto, Ryan, dímelo fai"}]}],"tags":[{"category":"_uncategorized_","tag":"NA"}],"uuid":"c7681a61-3678-407f-a749-7d774ad8acbc"},{"start_time":99,"end_time":101,"annotation":[{"type":"paragraph","children":[{"text":"Tú e[-]tá[-] deli, Bon Ice, salúdame a tu mai"}]}],"tags":[{"category":"Sociolinguistic Behavior","tag":"s-reduction"},{"category":"Linguistic Level","tag":"phonology"},{"category":"Artists","tag":"J Balvin"}],"uuid":"071c37ab-1127-4b3b-a9b3-704512c12fb2"},{"start_time":101,"end_time":104,"annotation":[{"type":"paragraph","children":[{"text":"Que e[-]ta noche me la llevo, vamo[-] a ver lo que hay"}]}],"tags":[{"category":"Sociolinguistic Behavior","tag":"s-reduction"},{"category":"Linguistic Level","tag":"phonology"},{"category":"Artists","tag":"J Balvin"}],"uuid":"4041a6df-4fc6-4e6e-869a-91893c9e32a9"},{"start_time":104,"end_time":106,"annotation":[{"type":"paragraph","ch